# Direct token auth (examples/direct_token.py)
# Optional local testing.
#
# Recommended production-like flow:
# https://github.com/civicteam/demos/tree/main/apps/civic-auth-demo-python-backend
#
# For local testing, generate a token at:
# https://app.civic.com/web/install/mcp-url
CIVIC_ACCESS_TOKEN=your-generated-access-token
# CIVIC_CLIENT_ID=your-client-id
# CIVIC_PROFILE_ID=optional-profile-id

# Token exchange (only for examples/token_exchange.py; uses CIVIC_ACCESS_TOKEN as subject token)
# CIVIC_CLIENT_ID=your-client-id
# CIVIC_CLIENT_SECRET=your-client-secret
# CIVIC_AUTH_URL=https://auth.civic.com/oauth/token
